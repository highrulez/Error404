# OneFlow — environment template (placeholders only)
# Copy to `.env` on the NAS or use `.env.local` for local npm run dev.
# Do NOT bake secrets into the Docker image or commit real values.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

SES_FROM_EMAIL=
SES_FROM_NAME=OneFlow

# mock | ses | both
EMAIL_MODE=both

# Production public URL (Open Form links in SES emails)
NEXT_PUBLIC_APP_URL=https://ppg.highrulez.com

# Optional fallback used by server email config if NEXT_PUBLIC_APP_URL is unset
# APP_URL=https://ppg.highrulez.com

# JSON map: mock @ppg-demo.com → real inbox (fill values on the NAS only)
EMAIL_RECIPIENT_MAP={"admin@ppg-demo.com":"","manager@ppg-demo.com":"","hr@ppg-demo.com":"","itsecurity@ppg-demo.com":"","alicia.wong@ppg-demo.com":"","daniel.lim@ppg-demo.com":""}

# Optional per-account aliases (alternative to EMAIL_RECIPIENT_MAP):
# EMAIL_MAP_ADMIN=
# EMAIL_MAP_ALICIA=
# EMAIL_MAP_DANIEL=
# EMAIL_MAP_manager=
# EMAIL_MAP_hr=
