# OneFlow — environment template for Synology / local Docker
# Copy to `.env` or set in Container Manager. Do NOT bake secrets into the image.

# mock | ses | both  (default: mock)
EMAIL_MODE=mock

AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

SES_FROM_EMAIL=noreply@example.com
SES_FROM_NAME=OneFlow

# Public app URL used in Open Form links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JSON map: mock @ppg-demo.com → real inbox
# EMAIL_RECIPIENT_MAP={"admin@ppg-demo.com":"real-admin@company.com","alicia.wong@ppg-demo.com":"real-onboarding@company.com","daniel.lim@ppg-demo.com":"real-offboarding@company.com","hr@ppg-demo.com":"hr@company.com"}

# Or per-account (aliases supported):
# EMAIL_MAP_ADMIN=real-admin@company.com
# EMAIL_MAP_ALICIA=real-onboarding@company.com
# EMAIL_MAP_DANIEL=real-offboarding@company.com
# EMAIL_MAP_manager=you@company.com
# EMAIL_MAP_hr=hr@company.com
# EMAIL_MAP_admin=admin@company.com
